import { VerticalBox, Button, CheckBox, ProgressIndicator, ComboBox, HorizontalBox } from "std-widgets.slint";

export component MainWindow inherits Window {
    width: 600px;
    height: 700px;
    title: "Image Upscaler";
    icon: @image-url("../app.ico");

    callback files_dropped(string);
    in property <string> status_text: "Drag and Drop Image here or Select File";
    in property <image> preview_image;
    in property <bool> has_image: false;
    
    in property <bool> is_processing: false;
    in property <float> progress: 0.0;

    // Model list and scaling options
    in property <[string]> models: ["No models found"];
    in-out property <int> selected_model_index: 0;
    out property <string> selected_model: root.models[root.selected_model_index];

    in property <[string]> scale_options: ["x2", "x3", "x4", "1M Pixels", "2M Pixels", "3M Pixels", "4M Pixels", "5M Pixels", "6M Pixels"];
    in-out property <int> selected_scale_index: 5;
    out property <string> selected_scale: root.scale_options[root.selected_scale_index];

    in property <[string]> tile_options: ["256x256", "512x512"];
    in-out property <int> selected_tile_index: 1;
    out property <string> selected_tile: root.tile_options[root.selected_tile_index];

    in-out property <string> output_folder: "";
    callback select_output_folder();

    VerticalBox {
        spacing: 10px;
        padding: 20px;

        Text {
            text: root.title;
            font-size: 24px;
            font-weight: 700;
            horizontal-alignment: center;
        }

        Text {
            text: root.status_text;
            horizontal-alignment: center;
            font-size: 14px;
            color: gray;
            wrap: word-wrap;
        }

        if (root.is_processing) : ProgressIndicator {
            progress: root.progress;
        }

        if (root.has_image) : Image {
            source: root.preview_image;
            max-width: 400px;
            max-height: 400px;
            image-fit: contain;
            horizontal-alignment: center;
        }

        // Pushes subsequent elements to the bottom
        Rectangle {
            vertical-stretch: 1;
        }

        HorizontalBox {
            alignment: center;
            height: 50px; // Fixed height for 1 line
            Text {
                 text: "Model: ";
                 width: 60px;
                 horizontal-alignment: right;
                 vertical-alignment: center;
            }
            ComboBox {
                width: 300px;
                model: root.models;
                current-index <=> root.selected_model_index;
            }
        }

        HorizontalBox {
            alignment: center;
            height: 50px; // Fixed height for 1 line
            Text {
                 text: "Scale: ";
                 width: 60px;
                 horizontal-alignment: right;
                 vertical-alignment: center;
            }
            ComboBox {
                width: 300px;
                model: root.scale_options;
                current-index <=> root.selected_scale_index;
            }
        }

        HorizontalBox {
            alignment: center;
            height: 50px; // Fixed height for 1 line
            Text {
                 text: "Tile: ";
                 width: 60px;
                 horizontal-alignment: right;
                 vertical-alignment: center;
            }
            ComboBox {
                width: 300px;
                model: root.tile_options;
                current-index <=> root.selected_tile_index;
            }
        }

        HorizontalBox {
            alignment: center;
            height: 50px; // Fixed height for 1 line
            Text {
                 text: "Output: ";
                 width: 60px;
                 horizontal-alignment: right;
                 vertical-alignment: center;
            }
            Text {
                 text: root.output_folder == "" ? "Same as image dir" : root.output_folder;
                 width: 140px;
                 vertical-alignment: center;
                 overflow: elide;
                 color: root.output_folder == "" ? gray : black;
            }
            Button {
                 text: "Browse...";
                 width: 75px;
                 clicked => { root.select_output_folder(); }
            }
            Button {
                 text: "Default";
                 width: 60px;
                 enabled: root.output_folder != "";
                 clicked => { root.output_folder = ""; }
            }
        }

        Button {
            text: "Select Image & Process";
            primary: true;
            height: 45px;
            enabled: !root.is_processing;
            clicked => {
                root.files-dropped("");
            }
        }
    }
}
